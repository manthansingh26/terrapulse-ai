# ==================== App Configuration ====================
APP_NAME="TerraPulse AI - Backend"
APP_VERSION="2.0.0"
DEBUG=False
API_PREFIX="/api"

# ==================== Database ====================
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/terrapulse_db

# ==================== Security ====================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== APIs ====================
WAQI_API_TOKEN=your-waqi-api-token
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ==================== Redis (Optional) ====================
REDIS_ENABLED=False
REDIS_URL=redis://localhost:6379

# ==================== Email Alerts ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=admin@terrapulse.com
AQI_ALERT_THRESHOLD=200

# ==================== CORS ====================
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8501","http://127.0.0.1:3000","*"]
