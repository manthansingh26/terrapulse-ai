# ============================================================================
# TerraPulse AI - Environment Configuration
# ============================================================================
# Copy this file to .env and configure with your values
# IMPORTANT: Never commit .env file with sensitive data to version control!
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=terrapulse_db
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/terrapulse_db

# ============================================================================
# JWT & AUTHENTICATION
# ============================================================================
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=TerraPulse AI API
API_VERSION=1.0.0
DEBUG=False

# ============================================================================
# EXTERNAL APIS
# ============================================================================
# WAQI Air Quality API: https://aqicn.org/api/
WAQI_API_KEY=demo
WAQI_API_URL=https://api.waqi.info

# OpenWeatherMap API: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_API_URL=https://api.openweathermap.org/data/2.5

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
# Gmail SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SENDER_EMAIL=TerraPulse AI <noreply@terrapulse.ai>

# Email Features
SEND_ALERTS=True
ALERT_THRESHOLD=150  # AQI threshold for alerts

# ============================================================================
# REDIS CONFIGURATION (Caching & Session Store)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
CACHE_EXPIRATION_HOURS=6

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_URL=http://localhost:3000
FRONTEND_BUILD_DIR=../frontend/dist

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ============================================================================
# WEBSOCKET CONFIGURATION
# ============================================================================
WS_ENABLED=True
WS_PORT=8000
WS_HEARTBEAT_INTERVAL=30  # seconds

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================================================
# PAGINATION & LIMITS
# ============================================================================
MAX_PAGE_SIZE=100
DEFAULT_PAGE_SIZE=20
MAX_HISTORY_DAYS=90
MAX_API_REQUESTS_PER_HOUR=1000

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_EMAIL_ALERTS=True
FEATURE_WEBSOCKET=True
FEATURE_ANALYTICS=True
FEATURE_ADMIN_PANEL=True

# ============================================================================
# SECURITY
# ============================================================================
ALLOWED_HOSTS=["localhost","127.0.0.1"]
SECURE_COOKIES=False  # Set to True in production
SECURE_HEADERS=True
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # seconds

# ============================================================================
# FRONTEND BUILD & VITE
# ============================================================================
VITE_API_URL=http://localhost:8000/api
VITE_WS_PORT=8000
VITE_APP_NAME=TerraPulse AI
VITE_DEBUG=true

# ============================================================================
# DOCKER ENVIRONMENT (Optional)
# ============================================================================
DOCKER_ENV=development
DOCKER_POSTGRES_PASSWORD=postgres
DOCKER_POSTGRES_USER=postgres
DOCKER_POSTGRES_DB=terrapulse_db

# ============================================================================
# WORKER & BACKGROUND JOBS
# ============================================================================
WORKER_ENABLED=True
WORKER_CONCURRENCY=4
DATA_SYNC_INTERVAL_MINUTES=30
CLEANUP_JOB_INTERVAL_HOURS=24

# ============================================================================
# PRODUCTION DEPLOYMENT (Fill only for production)
# ============================================================================
# PRODUCTION_URL=https://api.terrapulse.ai
# PRODUCTION_DOMAIN=terrapulse.ai
# SENTRY_DSN=
# SENTRY_ENABLED=False

# ============================================================================
# AWS/CLOUD CONFIGURATION (If deploying to cloud)
# ============================================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=
# AWS_RDS_ENDPOINT=

# ============================================================================
# MONITORING & METRICS
# ============================================================================
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
METRICS_ENABLED=True

# ============================================================================
# END OF CONFIGURATION
# ============================================================================
