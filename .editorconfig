# ============================================================================
# EditorConfig - Helps maintain consistent coding styles across editors
# ============================================================================
# See https://editorconfig.org for more information

root = true

# ============================================================================
# All Files
# ============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ============================================================================
# Python Files
# ============================================================================
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100
quote_type = double

# ============================================================================
# JavaScript/TypeScript/React Files
# ============================================================================
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_style = space
indent_size = 2
max_line_length = 100
quote_type = single

# ============================================================================
# JSON Files
# ============================================================================
[*.{json,jsonc}]
indent_style = space
indent_size = 2

# ============================================================================
# YAML/YAML Configuration Files
# ============================================================================
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ============================================================================
# Markdown Files
# ============================================================================
[*.md]
trim_trailing_whitespace = false
insert_final_newline = true

# ============================================================================
# Shell Scripts
# ============================================================================
[*.{sh,bash}]
indent_style = space
indent_size = 2

# ============================================================================
# Docker Files
# ============================================================================
[{Dockerfile,Dockerfile.*,.dockerignore}]
indent_style = space
indent_size = 2

# ============================================================================
# Configuration Files
# ============================================================================
[{.env*,*.cfg,*.ini,*.conf,*.config}]
indent_style = space
indent_size = 2
